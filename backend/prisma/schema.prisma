generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  logoUrl       String?
  themeConfig   Json?
  isActive      Boolean        @default(true)
  bio           String?
  instagramUrl  String?
  linkedinUrl   String?
  twitterUrl    String?
  websiteUrl    String?
  coverUrl      String?
  activityTypes ActivityType[]
  auditLogs     AuditLog[]
  badges        Badge[]
  events        Event[]
  speakers      Speaker[]
  speakerRoles  SpeakerRole[]
  users         User[]
}

model User {
  id                   String               @id @default(cuid())
  email                String               @unique
  password             String
  name                 String
  role                 UserRole
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  tenantId             String?
  avatarUrl            String?
  bio                  String?
  resetPasswordExpires DateTime?
  resetPasswordToken   String?
  mustChangePassword   Boolean              @default(false)
  coins                Int                  @default(0)
  interests            String[]             @default([])
  level                Int                  @default(1)
  profileTheme         String?              @default("zinc")
  publicProfile        Boolean              @default(false)
  username             String?              @unique
  xp                   Int                  @default(0)
  auditLogs            AuditLog[]
  claimCodes           BadgeClaimCode[]
  eventMonitors        EventMonitor[]
  eventReviewers       EventReviewer[]
  gamificationAlerts   GamificationAlert[]
  registrations        Registration[]
  reviews              Review[]
  acceptedInvitations  ReviewerInvitation[] @relation("AcceptedByUser")
  reviewerInvitations  ReviewerInvitation[] @relation("InvitedByUser")
  speaker              Speaker?
  submissions          Submission[]         @relation("SubmissionAuthor")
  kanbanAssignments    TaskAssignment[]
  kanbanComments       TaskComment[]
  tenant               Tenant?              @relation(fields: [tenantId], references: [id])
  userBadges           UserBadge[]
  xpLogs               XpGainLog[]
  issuedCertificates   IssuedCertificate[]
  refreshTokens        RefreshToken[]
  gamificationConfigs  GamificationConfig[] @relation("GamificationConfigUpdatedBy")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ip        String?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Event {
  id                       String                @id @default(cuid())
  tenantId                 String
  name                     String
  slug                     String
  description              String?
  location                 String?
  startDate                DateTime
  endDate                  DateTime
  status                   EventStatus           @default(DRAFT)
  bannerUrl                String?
  logoUrl                  String?
  themeConfig              Json?
  seoTitle                 String?
  seoDescription           String?
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  reviewEndDate            DateTime?
  reviewStartDate          DateTime?
  scientificCommitteeEmail String?
  scientificCommitteeHead  String?
  submissionEndDate        DateTime?
  submissionStartDate      DateTime?
  submissionsEnabled       Boolean               @default(false)
  activities               Activity[]
  auditLogs                AuditLog[]
  badges                   Badge[]
  certificateTemplates     CertificateTemplate[]
  forms                    CustomForm[]
  tenant                   Tenant                @relation(fields: [tenantId], references: [id])
  monitors                 EventMonitor[]
  reviewers                EventReviewer[]
  gamificationAlerts       GamificationAlert[]
  kanbanBoards             KanbanBoard[]
  raffleHistories          RaffleHistory[]
  registrations            Registration[]
  reviewerInvitations      ReviewerInvitation[]
  sponsorCategories        SponsorCategory[]
  submissions              Submission[]
  submissionModalities     SubmissionModality[]
  submissionRules          SubmissionRule[]
  thematicAreas            ThematicArea[]
  tickets                  Ticket[]
  userBadges               UserBadge[]
  xpLogs                   XpGainLog[]

  @@unique([tenantId, slug])
}

model KanbanBoard {
  id        String         @id @default(cuid())
  eventId   String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  name      String         @default("Quadro Principal")
  event     Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  columns   KanbanColumn[]

  @@index([eventId])
}

model KanbanColumn {
  id        String       @id @default(cuid())
  boardId   String
  name      String
  order     Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  color     String       @default("zinc")
  board     KanbanBoard  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks     KanbanTask[]

  @@index([boardId])
}

model KanbanTask {
  id                String           @id @default(cuid())
  columnId          String
  title             String
  description       String?
  priority          TaskPriority     @default(MEDIUM)
  deadline          DateTime?
  order             Int              @default(0)
  externalReference String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  column            KanbanColumn     @relation(fields: [columnId], references: [id], onDelete: Cascade)
  assignments       TaskAssignment[]
  comments          TaskComment[]

  @@index([columnId])
}

model TaskAssignment {
  taskId     String
  userId     String
  assignedAt DateTime   @default(now())
  task       KanbanTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
}

model TaskComment {
  id        String     @id @default(cuid())
  taskId    String
  userId    String
  content   String
  createdAt DateTime   @default(now())
  task      KanbanTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id])

  @@index([taskId])
}

model ActivityType {
  id         String     @id @default(cuid())
  tenantId   String
  name       String
  activities Activity[]
  tenant     Tenant     @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, name])
}

model SpeakerRole {
  id               String            @id @default(cuid())
  tenantId         String
  name             String
  activitySpeakers ActivitySpeaker[]
  tenant           Tenant            @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, name])
}

model Activity {
  id                   String               @id @default(cuid())
  eventId              String
  title                String
  description          String?
  location             String?
  startAt              DateTime
  endAt                DateTime
  capacity             Int?
  status               ActivityStatus       @default(SCHEDULED)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  requiresEnrollment   Boolean              @default(false)
  typeId               String?
  confirmationDays     Int?
  requiresConfirmation Boolean              @default(false)
  event                Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  type                 ActivityType?        @relation(fields: [typeId], references: [id])
  enrollments          ActivityEnrollment[]
  feedbacks            ActivityFeedback[]
  materials            ActivityMaterial[]
  speakers             ActivitySpeaker[]
  attendances          Attendance[]
  raffleHistories      RaffleHistory[]
  issuedCertificates   IssuedCertificate[]
}

model Speaker {
  id          String            @id @default(cuid())
  tenantId    String
  name        String
  bio         String?
  avatarUrl   String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  email       String?
  linkedinUrl String?
  websiteUrl  String?
  userId      String?           @unique
  activities  ActivitySpeaker[]
  tenant      Tenant            @relation(fields: [tenantId], references: [id])
  user        User?             @relation(fields: [userId], references: [id])
}

model ActivitySpeaker {
  activityId String
  speakerId  String
  roleId     String?
  activity   Activity     @relation(fields: [activityId], references: [id], onDelete: Cascade)
  role       SpeakerRole? @relation(fields: [roleId], references: [id])
  speaker    Speaker      @relation(fields: [speakerId], references: [id], onDelete: Cascade)

  @@id([activityId, speakerId])
}

model Registration {
  id                String               @id @default(cuid())
  eventId           String
  userId            String
  createdAt         DateTime             @default(now())
  enrollments       ActivityEnrollment[]
  activityFeedbacks ActivityFeedback[]
  formResponses     CustomFormResponse[]
  certificates      IssuedCertificate[]
  raffleHistories   RaffleHistory[]
  event             Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user              User                 @relation(fields: [userId], references: [id])
  tickets           Ticket[]
}

model ActivityEnrollment {
  id             String           @id @default(cuid())
  activityId     String
  registrationId String
  createdAt      DateTime         @default(now())
  confirmedAt    DateTime?
  status         EnrollmentStatus @default(CONFIRMED)
  activity       Activity         @relation(fields: [activityId], references: [id], onDelete: Cascade)
  registration   Registration     @relation(fields: [registrationId], references: [id], onDelete: Cascade)
}

model Ticket {
  id             String       @id @default(cuid())
  eventId        String
  registrationId String
  type           TicketType   @default(FREE)
  status         TicketStatus @default(PENDING)
  price          Decimal      @default(0)
  qrCodeToken    String?      @unique
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  attendances    Attendance[]
  event          Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
}

model CustomForm {
  id        String               @id @default(cuid())
  eventId   String
  name      String
  type      FormType
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  event     Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  fields    CustomFormField[]
  responses CustomFormResponse[]
}

model CustomFormField {
  id        String             @id @default(cuid())
  formId    String
  label     String
  type      FormFieldType
  required  Boolean            @default(false)
  order     Int
  options   Json?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  answers   CustomFormAnswer[]
  form      CustomForm         @relation(fields: [formId], references: [id], onDelete: Cascade)
}

model CustomFormResponse {
  id             String             @id @default(cuid())
  formId         String
  registrationId String?
  submissionId   String?
  createdAt      DateTime           @default(now())
  answers        CustomFormAnswer[]
  form           CustomForm         @relation(fields: [formId], references: [id], onDelete: Cascade)
  registration   Registration?      @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  submission     Submission?        @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

model CustomFormAnswer {
  id         String             @id @default(cuid())
  responseId String
  fieldId    String
  value      String
  field      CustomFormField    @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  response   CustomFormResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
}

model Submission {
  id             String               @id @default(cuid())
  eventId        String
  authorId       String
  title          String
  abstract       String?
  fileUrl        String
  status         SubmissionStatus     @default(SUBMITTED)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  modalityId     String?
  thematicAreaId String?
  formResponses  CustomFormResponse[]
  reviews        Review[]
  author         User                 @relation("SubmissionAuthor", fields: [authorId], references: [id])
  event          Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  modality       SubmissionModality?  @relation(fields: [modalityId], references: [id])
  thematicArea   ThematicArea?        @relation(fields: [thematicAreaId], references: [id])
}

model Review {
  id             String                @id @default(cuid())
  submissionId   String
  reviewerId     String
  score          Int?
  recommendation ReviewRecommendation?
  comments       String?
  createdAt      DateTime              @default(now())
  reviewer       User                  @relation(fields: [reviewerId], references: [id])
  submission     Submission            @relation(fields: [submissionId], references: [id])
}

model EventReviewer {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model ReviewerInvitation {
  id           String           @id @default(cuid())
  eventId      String
  email        String
  token        String           @unique
  status       InvitationStatus @default(PENDING)
  expiresAt    DateTime
  invitedById  String
  acceptedById String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  acceptedBy   User?            @relation("AcceptedByUser", fields: [acceptedById], references: [id])
  event        Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  invitedBy    User             @relation("InvitedByUser", fields: [invitedById], references: [id])

  @@unique([eventId, email])
}

model SubmissionModality {
  id          String       @id @default(cuid())
  eventId     String
  name        String
  description String?
  templateUrl String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  submissions Submission[]
  event       Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, name])
}

model ThematicArea {
  id          String       @id @default(cuid())
  eventId     String
  name        String
  createdAt   DateTime     @default(now())
  submissions Submission[]
  event       Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, name])
}

model SubmissionRule {
  id        String   @id @default(cuid())
  eventId   String
  title     String
  fileUrl   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model Attendance {
  id         String    @id @default(cuid())
  ticketId   String
  activityId String?
  checkedAt  DateTime  @default(now())
  activity   Activity? @relation(fields: [activityId], references: [id], onDelete: Cascade)
  ticket     Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

enum CertificateCategory {
  PARTICIPANT
  SPEAKER
  REVIEWER
  MONITOR
}

model CertificateTemplate {
  id                 String              @id @default(cuid())
  eventId            String
  name               String
  backgroundUrl      String
  layoutConfig       Json
  category           CertificateCategory @default(PARTICIPANT)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  event              Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  issuedCertificates IssuedCertificate[]
}

model IssuedCertificate {
  id             String              @id @default(cuid())
  templateId     String
  registrationId String?
  userId         String?
  activityId     String?
  fileUrl        String
  metadata       Json?
  issuedAt       DateTime            @default(now())
  validationHash String              @unique @default(uuid())
  registration   Registration?       @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  user           User?               @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity       Activity?           @relation(fields: [activityId], references: [id], onDelete: Cascade)
  template       CertificateTemplate @relation(fields: [templateId], references: [id])

  @@unique([templateId, registrationId, userId, activityId])
}

model SponsorCategory {
  id           String      @id @default(cuid())
  eventId      String
  name         String
  displayOrder Int         @default(0)
  size         SponsorSize @default(MEDIUM)
  color        String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  sponsors     Sponsor[]
  event        Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model Sponsor {
  id           String          @id @default(cuid())
  categoryId   String
  name         String
  logoUrl      String
  websiteUrl   String?
  displayOrder Int             @default(0)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  category     SponsorCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

model RaffleHistory {
  id             String       @id @default(cuid())
  eventId        String
  activityId     String?
  registrationId String
  prizeName      String?
  rule           RaffleRule   @default(ONLY_CHECKED_IN)
  hasReceived    Boolean      @default(false)
  drawnAt        DateTime     @default(now())
  activity       Activity?    @relation(fields: [activityId], references: [id], onDelete: Cascade)
  event          Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
}

model Badge {
  id                 String             @id @default(cuid())
  tenantId           String
  eventId            String?
  name               String
  description        String?
  iconUrl            String?
  color              String             @default("blue")
  triggerRule        BadgeTrigger       @default(MANUAL)
  manualDeliveryMode ManualDeliveryMode @default(GLOBAL_CODE)
  minRequirement     Int?               @default(0)
  claimCode          String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  event              Event?             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tenant             Tenant             @relation(fields: [tenantId], references: [id])
  claimCodes         BadgeClaimCode[]
  userBadges         UserBadge[]
}

model BadgeClaimCode {
  id        String    @id @default(cuid())
  badgeId   String
  code      String    @unique
  isUsed    Boolean   @default(false)
  userId    String?
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  badge     Badge     @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id])

  @@index([badgeId])
  @@index([code])
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  eventId  String?
  earnedAt DateTime @default(now())
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  event    Event?   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@unique([userId, badgeId, eventId])
}

model ActivityMaterial {
  id         String   @id @default(cuid())
  activityId String
  title      String
  fileUrl    String
  fileType   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
}

model ActivityFeedback {
  id             String        @id @default(cuid())
  activityId     String
  rating         Int
  comment        String?
  registrationId String?
  isAnonymous    Boolean       @default(false)
  createdAt      DateTime      @default(now())
  activity       Activity      @relation(fields: [activityId], references: [id], onDelete: Cascade)
  registration   Registration? @relation(fields: [registrationId], references: [id])
}

model EventMonitor {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model XpGainLog {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  reason    String
  createdAt DateTime @default(now())
  uniqueKey String?
  eventId   String?
  event     Event?   @relation(fields: [eventId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, uniqueKey])
  @@index([userId, createdAt])
  @@index([eventId, createdAt])
}

model GamificationAlert {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  type      String
  message   String
  metadata  Json?
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([eventId, createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  eventId    String?
  userId     String
  action     String
  resource   String
  resourceId String?
  payload    Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())
  tenantId   String?
  event      Event?   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tenant     Tenant?  @relation(fields: [tenantId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@index([eventId, createdAt])
  @@index([userId, createdAt])
  @@index([tenantId, createdAt])
}

enum UserRole {
  ORGANIZER
  REVIEWER
  PARTICIPANT
  SPEAKER
  SUPER_ADMIN
}

enum TicketType {
  FREE
  PAID
}

enum TicketStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum SubmissionStatus {
  SUBMITTED
  UNDER_REVIEW
  ACCEPTED
  REJECTED
}

enum EventStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum EnrollmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum ActivityStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
}

enum FormType {
  REGISTRATION
  SUBMISSION
}

enum FormFieldType {
  TEXT
  TEXTAREA
  SELECT
  MULTISELECT
  CHECKBOX
  DATE
  NUMBER
  EMAIL
}

enum ReviewRecommendation {
  STRONG_ACCEPT
  ACCEPT
  WEAK_ACCEPT
  BORDERLINE
  WEAK_REJECT
  REJECT
  STRONG_REJECT
}

enum RaffleRule {
  ALL_REGISTERED
  ONLY_CHECKED_IN
}

enum SponsorSize {
  SMALL
  MEDIUM
  LARGE
}

enum BadgeTrigger {
  MANUAL
  RAFFLE_WINNER
  EARLY_BIRD
  CHECKIN_STREAK
  ACTIVITY_HOURS
  EVENT_COUNT
  PROFILE_COMPLETED
}

enum ManualDeliveryMode {
  SCAN
  UNIQUE_CODES
  GLOBAL_CODE
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

model GamificationConfig {
  id                   String   @id @default(cuid())
  dailyXpLimit         Int      @default(1500)
  levelFormulaBase     Int      @default(500)
  levelFormulaExponent Float    @default(0.6)
  spikeThreshold       Int      @default(1000)
  spikeWindowMinutes   Int      @default(5)
  updatedAt            DateTime @updatedAt
  updatedById          String?
  updatedBy            User?    @relation("GamificationConfigUpdatedBy", fields: [updatedById], references: [id])
}

model XpActionConfig {
  id          String   @id @default(cuid())
  actionKey   String   @unique
  label       String
  description String?
  xpAmount    Int
  isActive    Boolean  @default(true)
  icon        String?
  category    String   @default("engagement")
  updatedAt   DateTime @updatedAt
}
