// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ORGANIZER
  REVIEWER
  SPEAKER
  PARTICIPANT
}

enum TicketType {
  FREE
  PAID
}

enum TicketStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum SubmissionStatus {
  SUBMITTED
  UNDER_REVIEW
  ACCEPTED
  REJECTED
}

enum EventStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum EnrollmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum ActivityStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
}

enum FormType {
  REGISTRATION
  SUBMISSION
}

enum FormFieldType {
  TEXT
  TEXTAREA
  SELECT
  MULTISELECT
  CHECKBOX
  DATE
  NUMBER
  EMAIL
}

enum ReviewRecommendation {
  STRONG_ACCEPT
  ACCEPT
  WEAK_ACCEPT
  BORDERLINE
  WEAK_REJECT
  REJECT
  STRONG_REJECT
}

enum RaffleRule {
  ALL_REGISTERED
  ONLY_CHECKED_IN
}

model Tenant {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logoUrl     String?
  themeConfig Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users         User[]
  events        Event[]
  speakers      Speaker[]
  activityTypes ActivityType[]
  speakerRoles  SpeakerRole[]
  badges        Badge[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole
  avatarUrl String?
  bio       String?
  
  refreshToken         String?
  resetPasswordToken   String?
  resetPasswordExpires DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  registrations Registration[]
  reviews       Review[]
  submissions   Submission[]   @relation("SubmissionAuthor")
  userBadges    UserBadge[]
  claimCodes    BadgeClaimCode[]
  eventReviewers      EventReviewer[]
  reviewerInvitations ReviewerInvitation[] @relation("InvitedByUser")
  acceptedInvitations ReviewerInvitation[] @relation("AcceptedByUser")
  mustChangePassword  Boolean              @default(false)
  speaker             Speaker?
}

model Event {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  name        String
  slug        String
  description String?
  location    String?
  startDate   DateTime
  endDate     DateTime
  status      EventStatus @default(DRAFT)

  bannerUrl      String?
  logoUrl        String?
  themeConfig    Json?
  seoTitle       String?
  seoDescription String?

  // === Submission Module Config ===
  submissionsEnabled       Boolean   @default(false)
  submissionStartDate      DateTime?
  submissionEndDate        DateTime?
  reviewStartDate          DateTime?
  reviewEndDate            DateTime?
  scientificCommitteeHead  String?
  scientificCommitteeEmail String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activities           Activity[]
  registrations        Registration[]
  tickets              Ticket[]
  forms                CustomForm[]
  submissions          Submission[]
  certificateTemplates CertificateTemplate[]
  sponsorCategories    SponsorCategory[]
  raffleHistories      RaffleHistory[]
  badges               Badge[]
  userBadges           UserBadge[]
  submissionModalities SubmissionModality[]
  thematicAreas        ThematicArea[]
  submissionRules      SubmissionRule[]
  reviewers            EventReviewer[]
  reviewerInvitations  ReviewerInvitation[]

  @@unique([tenantId, slug])
}

model ActivityType {
  id         String     @id @default(cuid())
  tenantId   String
  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  name       String
  activities Activity[]

  @@unique([tenantId, name])
}

model SpeakerRole {
  id               String            @id @default(cuid())
  tenantId         String
  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  name             String
  activitySpeakers ActivitySpeaker[]

  @@unique([tenantId, name])
}

model Activity {
  id      String @id @default(cuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  title       String
  description String?
  location    String?
  startAt     DateTime
  endAt       DateTime
  capacity    Int?
  status      ActivityStatus @default(SCHEDULED)

  typeId               String?
  type                 ActivityType? @relation(fields: [typeId], references: [id])
  requiresEnrollment   Boolean       @default(false)
  requiresConfirmation Boolean       @default(false)
  confirmationDays     Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  speakers        ActivitySpeaker[]
  enrollments     ActivityEnrollment[]
  attendances     Attendance[]
  raffleHistories RaffleHistory[]
  materials       ActivityMaterial[]
  feedbacks       ActivityFeedback[]
}

model Speaker {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  name        String
  email       String?
  bio         String?
  avatarUrl   String?
  linkedinUrl String?
  websiteUrl  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId    String?  @unique
  user      User?    @relation(fields: [userId], references: [id])

  activities ActivitySpeaker[]
}

model ActivitySpeaker {
  activityId String
  speakerId  String
  roleId     String?

  activity Activity     @relation(fields: [activityId], references: [id], onDelete: Cascade)
  speaker  Speaker      @relation(fields: [speakerId], references: [id], onDelete: Cascade)
  role     SpeakerRole? @relation(fields: [roleId], references: [id])

  @@id([activityId, speakerId])
}

model Registration {
  id      String @id @default(cuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  tickets         Ticket[]
  enrollments     ActivityEnrollment[]
  formResponses   CustomFormResponse[]
  certificates    IssuedCertificate[]
  raffleHistories RaffleHistory[]
  activityFeedbacks ActivityFeedback[]
}

model ActivityEnrollment {
  id         String   @id @default(cuid())
  activityId String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  registrationId String
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  status      EnrollmentStatus @default(CONFIRMED)
  confirmedAt DateTime?

  createdAt DateTime @default(now())
}

model Ticket {
  id      String @id @default(cuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  registrationId String
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  type   TicketType   @default(FREE)
  status TicketStatus @default(PENDING)
  price  Decimal      @default(0)

  qrCodeToken String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attendances Attendance[]
}

model CustomForm {
  id      String @id @default(cuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  name String
  type FormType

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  responses CustomFormResponse[]
  fields    CustomFormField[]
}

model CustomFormField {
  id     String     @id @default(cuid())
  formId String
  form   CustomForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  label    String
  type     FormFieldType
  required Boolean       @default(false)
  order    Int
  options  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  answers CustomFormAnswer[]
}

model CustomFormResponse {
  id     String     @id @default(cuid())
  formId String
  form   CustomForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  registrationId String?
  registration   Registration? @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  submissionId String?
  submission   Submission? @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  answers CustomFormAnswer[]
}

model CustomFormAnswer {
  id         String             @id @default(cuid())
  responseId String
  response   CustomFormResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)

  fieldId String
  field   CustomFormField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  value String
}

model Submission {
  id      String @id @default(cuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation("SubmissionAuthor", fields: [authorId], references: [id])

  title    String
  abstract String?
  fileUrl  String
  status   SubmissionStatus @default(SUBMITTED)

  modalityId     String?
  modality       SubmissionModality? @relation(fields: [modalityId], references: [id])

  thematicAreaId String?
  thematicArea   ThematicArea? @relation(fields: [thematicAreaId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reviews       Review[]
  formResponses CustomFormResponse[]
}

model Review {
  id           String     @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id])

  reviewerId String
  reviewer   User   @relation(fields: [reviewerId], references: [id])

  score          Int?
  recommendation ReviewRecommendation?
  comments       String?

  createdAt DateTime @default(now())
}

model EventReviewer {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([eventId, userId])
}

model ReviewerInvitation {
  id          String           @id @default(cuid())
  eventId     String
  event       Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  email       String
  token       String           @unique
  status      InvitationStatus @default(PENDING)
  expiresAt   DateTime
  invitedById String
  invitedBy   User             @relation("InvitedByUser", fields: [invitedById], references: [id])
  acceptedById String?
  acceptedBy  User?            @relation("AcceptedByUser", fields: [acceptedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, email])
}

model SubmissionModality {
  id          String  @id @default(cuid())
  eventId     String
  event       Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)

  name        String
  description String?
  templateUrl String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  submissions Submission[]

  @@unique([eventId, name])
}

model ThematicArea {
  id      String @id @default(cuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  name    String

  createdAt DateTime @default(now())

  submissions Submission[]

  @@unique([eventId, name])
}

model SubmissionRule {
  id      String @id @default(cuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  title   String
  fileUrl String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Attendance {
  id String @id @default(cuid())

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  activityId String?
  activity   Activity? @relation(fields: [activityId], references: [id], onDelete: Cascade)

  checkedAt DateTime @default(now())
}

model CertificateTemplate {
  id      String @id @default(cuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  name          String
  backgroundUrl String
  layoutConfig  Json // Coordenadas e estilos vindos do frontend

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  issuedCertificates IssuedCertificate[]
}

model IssuedCertificate {
  id String @id @default(cuid())

  templateId String
  template   CertificateTemplate @relation(fields: [templateId], references: [id])

  registrationId String
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  fileUrl        String
  validationHash String   @unique @default(uuid())
  issuedAt       DateTime @default(now())
}

enum SponsorSize {
  SMALL
  MEDIUM
  LARGE
}

model SponsorCategory {
  id      String @id @default(cuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  name         String
  displayOrder Int         @default(0)
  size         SponsorSize @default(MEDIUM)
  color        String? // Hex color for the category (e.g., Gold)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sponsors Sponsor[]
}

model Sponsor {
  id         String          @id @default(cuid())
  categoryId String
  category   SponsorCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  name         String
  logoUrl      String
  websiteUrl   String?
  displayOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RaffleHistory {
  id      String @id @default(cuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  activityId String?
  activity   Activity? @relation(fields: [activityId], references: [id], onDelete: Cascade)

  registrationId String
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  prizeName   String?
  rule        RaffleRule @default(ONLY_CHECKED_IN)
  hasReceived Boolean    @default(false)

  drawnAt DateTime @default(now())
}

enum BadgeTrigger {
  MANUAL
  RAFFLE_WINNER
  EARLY_BIRD
  CHECKIN_STREAK
  ACTIVITY_HOURS
  EVENT_COUNT
  PROFILE_COMPLETED
}

enum ManualDeliveryMode {
  SCAN
  UNIQUE_CODES
  GLOBAL_CODE
}

model Badge {
  id       String  @id @default(cuid())
  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id])
  eventId  String?
  event    Event?  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  name        String
  description String?
  iconUrl     String? // Pode ser Emoji ou URL SVG
  color       String       @default("blue") // blue, purple, gold, emerald
  triggerRule BadgeTrigger @default(MANUAL)
  manualDeliveryMode ManualDeliveryMode @default(GLOBAL_CODE)
  minRequirement Int?      @default(0) // Quantidade para Early Bird ou Check-in Streak
  claimCode      String?   // Código secreto para reivindicação manual (Global)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userBadges UserBadge[]
  claimCodes BadgeClaimCode[]
}

model BadgeClaimCode {
  id      String @id @default(cuid())
  badgeId String
  badge   Badge  @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  
  code    String @unique
  isUsed  Boolean @default(false)
  userId  String?
  user    User?   @relation(fields: [userId], references: [id])
  usedAt  DateTime?

  createdAt DateTime @default(now())

  @@index([badgeId])
  @@index([code])
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  badgeId  String
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  eventId  String?
  event    Event?   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  earnedAt DateTime @default(now())

  // Garante que o usuário só ganhe a mesma badge 1 vez por evento
  @@unique([userId, badgeId, eventId])
}

model ActivityMaterial {
  id         String   @id @default(cuid())
  activityId String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  
  title      String
  fileUrl    String
  fileType   String? // PDF, ZIP, SLIDES
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ActivityFeedback {
  id         String   @id @default(cuid())
  activityId String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  
  rating     Int      // 1-5
  comment    String?
  
  registrationId String?
  registration   Registration? @relation(fields: [registrationId], references: [id])

  createdAt  DateTime @default(now())
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

