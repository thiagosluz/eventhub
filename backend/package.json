    "test:cov": "jest --coverage --maxWorkers=2 --logHeapUsage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json --maxWorkers=2 --logHeapUsage",
    "test:seq": "jest --runInBand --logHeapUsage"
