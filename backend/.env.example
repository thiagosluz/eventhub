# =============================================================================
# EventHub Backend - Environment Variables
# Copy this file to .env and adjust values for your environment.
# =============================================================================

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Database (PostgreSQL) ---
DATABASE_URL="postgresql://eventhub:eventhub@localhost:5432/eventhub"

# --- Auth (JWT) ---
# Generate a strong secret in production: openssl rand -hex 48
JWT_SECRET="dev-super-secret-change-me"

# --- Redis (used by BullMQ) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- SMTP (MailHog em dev; SMTP real em produção) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
MAIL_FROM="noreply@eventhub.local"

# --- MinIO / S3-compatible storage ---
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
# URL pública usada para gerar links dos objetos (ex.: https://cdn.example.com).
# Em dev, deixar vazio aponta para http://localhost:<MINIO_PORT>.
MINIO_PUBLIC_URL=

# --- CORS / Frontend ---
# Lista separada por vírgula. Default: http://localhost:3000 e :3001
CORS_ORIGIN="http://localhost:3001,http://localhost:3000"
# URL base do frontend usada em e-mails transacionais e certificados
FRONTEND_URL="http://localhost:3001"

# --- Observabilidade (opcionais) ---
# Se SENTRY_DSN estiver vazio, Sentry fica desligado.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
# Habilita rota GET /metrics (Prometheus). Default: false
ENABLE_METRICS=false

# --- Logger ---
# debug | info | warn | error (default: info em prod, debug em dev)
LOG_LEVEL=
